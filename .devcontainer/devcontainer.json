{
  "name": "Swift",
  "image": "swift:5.7",
  "runArgs": [
    "--cap-add=SYS_PTRACE",
    "--security-opt",
    "seccomp=unconfined"
  ],
  "onCreateCommand": "apt-get update && apt install -y libpython3-dev python3-lldb && ln -s /usr/lib/llvm-14/libpython3.10/dist-packages/lldb/* /usr/lib/python3/distpackages/lldb/“ , 
"settings": { “lldb.library” : “/usr/lib/liblldb.so” },
  "extensions": [ "sswg.swift-lang" ] 
}
